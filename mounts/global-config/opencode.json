{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "deny",
    "write": "deny",
    "edit": "deny",
    "bash": "deny"
  },
  "mcp": {
    "reddit": {
      "type": "local",
      "command": ["npx", "-y", "reddit-mcp-buddy"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    }
  }
}
